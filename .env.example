# Optional — without it, discovery uses the keyless ListenBrainz/MusicBrainz APIs.
# A key from https://www.last.fm/api/account/create switches to Last.fm data.
LASTFM_API_KEY=

# Contact email for the MusicBrainz user-agent (their API policy)
MUSICBRAINZ_CONTACT=you@example.com

# Optional overrides (defaults shown)
#MUSICSEER_PORT=8688
#MUSICSEER_DATA_DIR=./data
#MUSICSEER_TRENDING_INTERVAL=6h
#MUSICSEER_LIBRARY_INTERVAL=12h
#MUSICSEER_RECS_TTL=12h
#MUSICSEER_LOG_LEVEL=info
